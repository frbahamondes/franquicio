<section>
    <h1>Noticias</h1>

    <nav class="categories">
        <a href="/noticias">Todas</a>
        {{#each categories}}
        <a href="/noticias?categoria={{this}}">{{this}}</a>
        {{/each}}
    </nav>

    {{#if news.length}}
        {{#each news}}
        <article class="news-card">
            <span class="category">{{this.category}}</span>
            <h3><a href="/noticias/{{this._id}}">{{this.title}}</a></h3>
            <p>{{this.excerpt}}</p>
        </article>
        {{/each}}
    {{else}}
        <p>No hay noticias en esta categoría.</p>
    {{/if}}
</section>